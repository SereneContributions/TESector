<Project>
  <PropertyGroup>
    <_ProjectDir>$([MSBuild]::EnsureTrailingSlash('$(MSBuildProjectDirectory)'))</_ProjectDir>
    <_RobustToolboxDir>$([MSBuild]::EnsureTrailingSlash('$(MSBuildThisFileDirectory)RobustToolbox'))</_RobustToolboxDir>
    <_CefGlueDir>$([MSBuild]::EnsureTrailingSlash('$(MSBuildThisFileDirectory)RobustToolbox\cefglue'))</_CefGlueDir>
    <_IsRobustToolboxProject>$([System.String]::Copy('$(_ProjectDir)').StartsWith('$(_RobustToolboxDir)'))</_IsRobustToolboxProject>
    <_IsCefGlueProject>$([System.String]::Copy('$(_ProjectDir)').StartsWith('$(_CefGlueDir)'))</_IsCefGlueProject>
  </PropertyGroup>

  <Import Project="$(MSBuildThisFileDirectory)RobustToolbox\cefglue\Directory.Build.props"
          Condition="'$(_IsCefGlueProject)' == 'True'" />

  <Import Project="$(MSBuildThisFileDirectory)RobustToolbox\Directory.Build.props"
          Condition="'$(_IsCefGlueProject)' != 'True' and '$(_IsRobustToolboxProject)' == 'True'" />

  <PropertyGroup>
    <DefaultItemExcludes>$(DefaultItemExcludes);**/bin/**;**/obj/**;**/tmpbuild/**</DefaultItemExcludes>
  </PropertyGroup>
</Project>